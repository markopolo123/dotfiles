# Read `man 5 sway` for a complete reference.

### Variables
#
# Logo key. Use Mod1 for Alt.
set $mod Mod1
# Home row direction keys, like vim
# set $left h
# set $down j
# set $up k
# set $right l
# Your preferred terminal emulator
set $term alacritty
# Your preferred application launcher
# Note: it's recommended that you pass the final command to sway
# set $menu dmenu_path | dmenu | xargs swaymsg exec --

# forcing wayland
# xwayland disable

#set $bg ~/Pictures/sunset.jpg
set $bg ~/Pictures/sunset.jpg

set $browser MOZ_ENABLE_WAYLAND=1 firefox
### menu
bindsym $mod+d exec wofi --show run

### Screen brightness
bindsym XF86MonBrightnessUp exec light -A 10
bindsym XF86MonBrightnessDown exec light -U 10

### Audio controls
bindsym XF86AudioRaiseVolume exec pamixer -u && pamixer -i 5
bindsym XF86AudioLowerVolume exec pamixer -u && pamixer -d 5
bindsym XF86AudioMute exec pamixer -t

### Output configuration
#
# Default wallpaper (more resolutions are available in @datadir@/backgrounds/sway/)
output * bg $bg fill

output eDP-1 scale 2

### Idle configuration
exec swayidle -w \
         timeout 300 'swaylock' \
         timeout 600 'swaymsg "output * dpms off"' \
              resume 'swaymsg "output * dpms on"' \
         before-sleep 'swaylock' \
         lock 'swaylock'

set $lock_bg ~/Pictures/sunset.jpg
bindsym $mod+Shift+l exec swaylock -i $lock_bg
#bindsym --release $mod+Shift+l exec loginctl lock-session

# disable idle if something is fullscreen (for videos)
for_window [class="^.*"] inhibit_idle fullscreen
for_window [app_id="^.*"] inhibit_idle fullscreen

### flashfocus
exec_always --no-startup-id flashfocus

### Input configuration
input "1:1:AT_Translated_Set_2_keyboard" {
    xkb_layout gb
    xkb_options ctrl:nocaps
    repeat_rate 80
    repeat_delay 500
}

input "1739:30383:DELL08AF:00_06CB:76AF_Touchpad" {
    tap enabled
    dwt enabled
    natural_scroll enabled
    accel_profile adaptive
    pointer_accel 0.65
}
#work inputs
input "1155:16385:CATEX_TECH._72M-RGB_Keyboard" {
    xkb_layout gb(intl)
    xkb_options ctrl:nocaps
    repeat_rate 80
    repeat_delay 250
}
input "1155:16385:CATEX_TECH._72M-RGB" {
    xkb_layout gb(intl)
    xkb_options ctrl:nocaps
    repeat_rate 80
    repeat_delay 250
}

input "1241:402:USB-HID_Keyboard" {
    xkb_layout gb
    xkb_options ctrl:nocaps
    repeat_rate 80
    repeat_delay 500
}
input "1452:613:Apple_Inc._Magic_Trackpad_2" {
    tap enabled
